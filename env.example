# ── Copie ce fichier en .env et remplis les valeurs ──────────
# Sur Render/Railway, ces variables se configurent dans le dashboard

# Clés d'accès à l'app
ADMIN_KEY=change-moi-admin
CREATOR_KEY=change-moi-creator

# Google Sheets
SPREADSHEET_ID=ton-spreadsheet-id-ici
GOOGLE_TOKEN_JSON={"token":"..."}   # contenu de google_token.json en une ligne

# Meta (Instagram + Facebook)
META_ACCESS_TOKEN=ton-token-meta
INSTAGRAM_BUSINESS_ID=ton-id-instagram
FACEBOOK_PAGE_ID=ton-id-page-facebook

# Paramètres
DAYS_TO_FETCH=7
CREATORS=Alice,Bob,Charlie   # noms des créateurs séparés par virgule

# Port (Render le définit automatiquement)
PORT=5000
